{
  "gateway": {
    "port": 7860,
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "mode": "lan",
    "bind": "127.0.0.1",
    "trustedProxies": "127.0.0.1"
  },
  "models": {
    "default": "claude-sonnet-4-20250514",
    "providers": [
      {
        "name": "anthropic",
        "type": "anthropic",
        "apiKey": "${ANTHROPIC_API_KEY}"
      }
    ]
  },
  "agents": [
    {
      "id": "default",
      "name": "Agente Principal",
      "model": "claude-sonnet-4-20250514",
      "provider": "anthropic"
    }
  ]
}
